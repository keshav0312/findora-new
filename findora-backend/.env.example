# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/findora

# Auth
JWT_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret

# CORS - comma separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# Optional: Cloudinary (photo uploads currently use local disk storage
# under /uploads — swap in Cloudinary here for production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL — used to build links inside transactional emails
FRONTEND_URL=http://localhost:3000

# Groq (AI match explanations) — free key at https://console.groq.com/keys
# App runs fine without this key: it falls back to a template explanation.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Brevo (transactional email: verification, password reset, match alerts)
# Free key at https://app.brevo.com -> Settings -> SMTP & API -> API Keys
# App runs fine without this key: emails are just logged to the console.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@findora.app
BREVO_SENDER_NAME=Findora
